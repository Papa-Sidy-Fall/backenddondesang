# Server
NODE_ENV=development
PORT=3000
JWT_SECRET=change-me-with-32-plus-chars
JWT_EXPIRES_IN=7d

# Database (Option 1)
DATABASE_URL=postgresql://user:password@localhost:5432/dondesang

# Database (Option 2)
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=dondesang

# Frontend allowed origins (comma-separated)
FRONTEND_URLS=http://localhost:5173,https://frontdondesang.vercel.app

# OAuth2 Google (required only if you use Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# Default backoffice accounts (created automatically if they don't exist)
DEFAULT_ADMIN_EMAIL=admin@dondesang.sn
DEFAULT_ADMIN_PASSWORD=Admin@2026
DEFAULT_DANTEC_EMAIL=dantec@dondesang.sn
DEFAULT_DANTEC_PASSWORD=Dantec@2026
DEFAULT_FANN_EMAIL=fann@dondesang.sn
DEFAULT_FANN_PASSWORD=Fann@2026

# Additional hospitals are auto-seeded from src/config/center-directory.ts
# Example: cnts@dondesang.sn / Cnts@2026

# Optional: required in production for /api/v1/logs
DEV_LOG_TOKEN=
DEV_LOG_EMAIL=dev.logs@dondesang.sn
DEV_LOG_PASSWORD=DevLogs@2026
